{
  "expo": {
    "name": "PokedexJunier",
    "slug": "curso1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "",
    "scheme": "curso1",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yunperez.curso1"
    },
    "web": {
      "output": "static",
      "favicon": "./public/app-icono.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./public/app-icono.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "271c73e4-1fe5-40f2-bffa-6f68084d0dff"
      }
    }
  }
}
